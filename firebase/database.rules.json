{
  "rules": {
    "deliveryApp": {
      "$empresaId": {
        "roles": {
          ".read": "auth != null && root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin'",
          ".write": "auth != null && root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin'",
          "$uid": {
            ".read": "auth != null && root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin'",
            ".write": "auth != null && root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin'",
            ".validate": "newData.val() === 'admin'"
          }
        },
        "drivers": {
          ".read": "auth != null && root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin'",
          "$driverUid": {
            ".read": "auth != null && (root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin' || auth.uid === $driverUid)",
            "profile": {
              ".write": "auth != null && root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin'"
            },
            "location": {
              ".write": "auth != null && auth.uid === $driverUid && root.child('deliveryApp').child($empresaId).child('drivers').child(auth.uid).child('profile').child('active').val() === true",
              ".validate": "newData.hasChildren(['lat','lng','updatedAt']) && newData.child('lat').isNumber() && newData.child('lng').isNumber() && newData.child('updatedAt').isNumber()"
            },
            "status": {
              ".write": "auth != null && auth.uid === $driverUid && root.child('deliveryApp').child($empresaId).child('drivers').child(auth.uid).child('profile').child('active').val() === true"
            }
          }
        },
        "deliveries": {
          ".read": "auth != null && (root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin' || ((query.orderByChild === 'driverId' || query.orderByChild === 'driverUid') && query.equalTo === auth.uid))",
          ".indexOn": [
            "driverId",
            "driverUid",
            "status",
            "createdAt"
          ],
          "$deliveryId": {
            ".read": "auth != null && (root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin' || data.child('driverId').val() === auth.uid || data.child('driverUid').val() === auth.uid)",
            ".write": "auth != null && root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin'",
            "status": {
              ".write": "auth != null && (root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin' || data.parent().child('driverId').val() === auth.uid || data.parent().child('driverUid').val() === auth.uid)"
            },
            "relato": {
              ".write": "auth != null && (root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin' || data.parent().child('driverId').val() === auth.uid || data.parent().child('driverUid').val() === auth.uid)"
            },
            "updatedAt": {
              ".write": "auth != null && (root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin' || data.parent().child('driverId').val() === auth.uid || data.parent().child('driverUid').val() === auth.uid)"
            },
            "deliveredAt": {
              ".write": "auth != null && (root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin' || data.parent().child('driverId').val() === auth.uid || data.parent().child('driverUid').val() === auth.uid)"
            }
          }
        },
        "$other": {
          ".read": "auth != null && root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin'",
          ".write": "auth != null && root.child('deliveryApp').child($empresaId).child('roles').child(auth.uid).val() === 'admin'"
        }
      }
    }
  }
}
